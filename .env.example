# Environment
NODE_ENV=development
PORT=5001

# Database
POSTGRES_URI=postgresql://username:password@localhost:5432/educado
POSTGRES_URI_DEV=postgresql://username:password@localhost:5432/educado_dev

# Frontend origin(s) for CORS (comma-separated)
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Auth (JWT)
# Use a strong random secret in production (example: openssl rand -base64 48)
ACCESS_TOKEN_SECRET=replace-with-a-strong-secret
# Optional legacy fallback (keep empty if unused)
JWT_SECRET=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=educado-media

# Email
EMAIL_API_KEY=
EMAIL_FROM=noreply@seudominio.com

# Redis / Queue
REDIS_HOST=localhost
REDIS_PORT=6379
