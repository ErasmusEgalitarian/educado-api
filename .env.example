# ============================================================
# Educado API — Variaveis de ambiente
# Copie para .env e ajuste os valores conforme o ambiente
# ============================================================

# ── Server ──────────────────────────────────────────────────
# development | staging | production
NODE_ENV=development
PORT=5001

# ── Database (PostgreSQL) ───────────────────────────────────
# Dev local: usa porta 5431 exposta pelo docker-compose
POSTGRES_URI_DEV=postgresql://educado:educado@localhost:5431/educado_dev
# Staging/Producao: configurar com host real (obrigatorio em prod)
POSTGRES_URI=postgresql://user:password@host:5432/educado

# ── CORS ────────────────────────────────────────────────────
# Origens permitidas (separadas por virgula)
# Dev: aceita localhost. Producao: restringir ao dominio real
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Auth (JWT) ──────────────────────────────────────────────
# OBRIGATORIO em producao. Gerar com: openssl rand -base64 48
ACCESS_TOKEN_SECRET=replace-with-a-strong-secret

# ── Storage (MinIO / S3) ────────────────────────────────────
# Dev local: MinIO via docker-compose em localhost:9000
# Producao: endpoint S3 real ou MinIO de producao
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=educado-media

# ── Email (Resend) ──────────────────────────────────────────
# Obter em https://resend.com/api-keys
EMAIL_API_KEY=
EMAIL_FROM=noreply@seudominio.com

# ── Redis / Fila de email (BullMQ) ─────────────────────────
# Dev local: Redis via docker-compose em localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Producao: configurar senha se necessario
# REDIS_PASSWORD=
