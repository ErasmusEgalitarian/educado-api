{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["jest", "node"],
    "typeRoots": [
      "./node_modules/@types",
      "./src/extended-types"
    ]
  },
  "include": ["src/**/*.ts"]
}
